# Database
NEON_DATABASE_URL=

# Band Orchestrator Agent
THENVOI_REST_URL=https://app.band.ai/
THENVOI_WS_URL=wss://app.band.ai/api/v1/socket/websocket
BAND_AGENT_ID=
BAND_API_KEY=
BAND_ROOM_ID=
# Per-event dynamic Band rooms. Default OFF: /analyze uses the shared BAND_ROOM_ID
# above. Set true ONLY when every pipeline agent shares ONE Band owner account
# (the orchestrator key can add same-owner agents only; cross-owner adds are 403
# and mentioning a non-member is 422). See backend/CLAUDE.md "Dynamic rooms".
DYNAMIC_BAND_ROOMS=false
# Pipeline agent ids — all added to each event's dynamically created Band room.
SATELLITE_AGENT_ID=a7e8e467-cf06-4bff-bf74-19439c4d6c4d
HAZARD_AGENT_ID=bc92035a-8f4d-4321-a014-bff1c5603c33
IMPACT_AGENT_ID=a9a1c74f-5d5e-4195-9177-87ede2807650
REPORT_AGENT_ID=cef0ed62-6539-4677-b7c1-0feebfb91c97
ORCHESTRATOR_MODEL=claude-sonnet-4-5-20250929

# AI/ML API — Band adapter + GPT fallback (OpenAI-compatible). GPT is the
# last-resort fallback in shared/utils/llm_fallback.py; the Band AnthropicAdapter
# routes through AIML's Anthropic endpoint (ANTHROPIC_BASE_URL).
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.aimlapi.com/v1
AIML_API_KEY=
OPENAI_BASE_URL=https://api.aimlapi.com/v1
GPT_FALLBACK_MODEL=gpt-5.5-2026-04-23

# Featherless (intelligence primary)
FEATHERLESS_API_KEY=

# Gemini (orchestrator adapter priority 1 + intelligence fallback 2).
# Leave GEMINI_API_KEY blank to fall back to Claude, then Featherless.
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-3.5-flash

# R2 Public
CLOUDFLARE_R2_PUBLIC=https://pub-720f47eaad2f4997a76a02f8bf14f58a.r2.dev

# App
PORT=8000
DEBUG=True

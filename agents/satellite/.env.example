# Featherless (PRIMARY) — backs both the Band LangGraph adapter (per-turn LLM)
# and the intelligence layer. Required.
FEATHERLESS_API_KEY=

# AIML + GPT last-resort fallback in shared/utils/llm_fallback.py only.
AIML_API_KEY=
OPENAI_BASE_URL=https://api.aimlapi.com/v1
GPT_FALLBACK_MODEL=gpt-5.5-2026-04-23

# Band SDK
THENVOI_REST_URL=https://app.band.ai/
THENVOI_WS_URL=wss://app.band.ai/api/v1/socket/websocket
BAND_AGENT_ID=
BAND_API_KEY=
# ANTHROPIC_API_KEY — optional. The Band adapter now uses Featherless; this is
# only consulted by the AIML/Anthropic-compatible fallback path if configured.
# ANTHROPIC_API_KEY=

# Copernicus Data Space Ecosystem
COPERNICUS_USERNAME=
COPERNICUS_PASSWORD=

# Cross-validation feeds (public, no auth). Leave blank to use the built-in
# defaults; set only to point at a mirror.
GDACS_GEOJSON_URL=
USGS_QUERY_URL=

# Cloudflare R2 (S3-compatible object storage)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_ENDPOINT=
CLOUDFLARE_R2_BUCKET=hazardmind-storage
CLOUDFLARE_R2_KEY=
CLOUDFLARE_R2_SECRET=
CLOUDFLARE_R2_PUBLIC_URL=

# Band agent registry
SATELLITE_AGENT_ID=
SATELLITE_HANDLE=
ORCHESTRATOR_AGENT_ID=
ORCHESTRATOR_HANDLE=
HAZARD_AGENT_ID=
HAZARD_HANDLE=
IMPACT_AGENT_ID=
IMPACT_HANDLE=
REPORT_AGENT_ID=
REPORT_HANDLE=
BAND_ROOM_ID=

# Band adapter + GPT fallback (AIML, OpenAI-compatible). GPT is the last-resort
# fallback in shared/utils/llm_fallback.py; the Band AnthropicAdapter routes
# through AIML's Anthropic endpoint (ANTHROPIC_BASE_URL).
AIML_API_KEY=
OPENAI_BASE_URL=https://api.aimlapi.com/v1
GPT_FALLBACK_MODEL=gpt-5.5-2026-04-23

# Featherless (intelligence primary)
FEATHERLESS_API_KEY=
NEON_DATABASE_URL=

# Band SDK
THENVOI_REST_URL=https://app.band.ai/
THENVOI_WS_URL=wss://app.band.ai/api/v1/socket/websocket
BAND_AGENT_ID=
BAND_API_KEY=
BAND_HANDLE=@geospatial.9660/hazardmind-impact
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.aimlapi.com/v1

# Cloudflare R2 (satellite image URLs)
CLOUDFLARE_R2_PUBLIC=https://pub-720f47eaad2f4997a76a02f8bf14f58a.r2.dev
R2_PUBLIC_BASE_URL=https://pub-720f47eaad2f4997a76a02f8bf14f58a.r2.dev

# GeoNames (population lookup)
GEONAMES_USERNAME=ahanan.24

# Runtime
USE_MOCK_BAND=false
